<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.luckyframe.project.testmanagmt.cicd.mapper.CiCdGitLabMapper">
    <resultMap type="CiCdGitLab" id="CiCdGitLabResult">
        <id property="gitlabId" column="gitlab_id" />
        <result property="projectId" column="project_id" />
        <result property="projectName" column="project_name" />
        <result property="gitlabName" column="gitlab_name" />
        <result property="gitlabUrl" column="gitlab_url" />
        <result property="projectPath" column="project_path" />
        <result property="accessToken" column="access_token" />
        <result property="status" column="status" />
        <result property="description" column="description" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <sql id="selectCiCdGitLabVo">
        select gitlab_id, project_id, project_name, gitlab_name, gitlab_url, project_path, access_token, status, description, create_time, update_time from project_cicd_gitlab
    </sql>

    <select id="selectCiCdGitLabById" parameterType="Long" resultMap="CiCdGitLabResult">
        <include refid="selectCiCdGitLabVo" />
        where gitlab_id = #{gitlabId}
    </select>

    <select id="selectCiCdGitLabList" parameterType="CiCdGitLab" resultMap="CiCdGitLabResult">
        <include refid="selectCiCdGitLabVo" />
        <where>
            <if test="projectId != null">
                and project_id = #{projectId}
            </if>
            <if test="status != null">
                and status = #{status}
            </if>
            <if test="gitlabName != null and gitlabName != ''">
                and gitlab_name like concat('%', #{gitlabName}, '%')
            </if>
        </where>
    </select>

    <insert id="insertCiCdGitLab" parameterType="CiCdGitLab" useGeneratedKeys="true" keyProperty="gitlabId">
        insert into project_cicd_gitlab
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="projectId != null">project_id,</if>
            <if test="projectName != null">project_name,</if>
            <if test="gitlabName != null">gitlab_name,</if>
            <if test="gitlabUrl != null">gitlab_url,</if>
            <if test="projectPath != null">project_path,</if>
            <if test="accessToken != null">access_token,</if>
            <if test="status != null">status,</if>
            <if test="description != null">description,</if>
            create_time,
            update_time
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="projectId != null">#{projectId},</if>
            <if test="projectName != null">#{projectName},</if>
            <if test="gitlabName != null">#{gitlabName},</if>
            <if test="gitlabUrl != null">#{gitlabUrl},</if>
            <if test="projectPath != null">#{projectPath},</if>
            <if test="accessToken != null">#{accessToken},</if>
            <if test="status != null">#{status},</if>
            <if test="description != null">#{description},</if>
            now(),
            now()
        </trim>
    </insert>

    <update id="updateCiCdGitLab" parameterType="CiCdGitLab">
        update project_cicd_gitlab
        <set>
            <if test="projectId != null">project_id = #{projectId},</if>
            <if test="projectName != null">project_name = #{projectName},</if>
            <if test="gitlabName != null">gitlab_name = #{gitlabName},</if>
            <if test="gitlabUrl != null">gitlab_url = #{gitlabUrl},</if>
            <if test="projectPath != null">project_path = #{projectPath},</if>
            <if test="accessToken != null">access_token = #{accessToken},</if>
            <if test="status != null">status = #{status},</if>
            <if test="description != null">description = #{description},</if>
            update_time = now()
        </set>
        where gitlab_id = #{gitlabId}
    </update>

    <delete id="deleteCiCdGitLabById" parameterType="Long">
        delete from project_cicd_gitlab where gitlab_id = #{gitlabId}
    </delete>

    <delete id="deleteCiCdGitLabByIds" parameterType="String">
        delete from project_cicd_gitlab where gitlab_id in
        <foreach item="gitlabId" collection="array" open="(" separator="," close=")">
            #{gitlabId}
        </foreach>
    </delete>

    <select id="selectCiCdGitLabByProjectId" parameterType="Long" resultMap="CiCdGitLabResult">
        <include refid="selectCiCdGitLabVo" />
        where project_id = #{projectId}
    </select>

    <select id="selectCiCdGitLabByStatus" parameterType="Integer" resultMap="CiCdGitLabResult">
        <include refid="selectCiCdGitLabVo" />
        where status = #{status}
    </select>
</mapper>